[server]
host = "0.0.0.0"
port = 8000
trusted_proxy_headers = true

[database]
app_url = "postgresql+asyncpg://postara@postgres:5432/postara"
audit_url = "postgresql+asyncpg://postara@postgres:5432/postara"
password_file = "/etc/postara/secrets/db_password.txt"
app_schema = "app"
audit_schema = "audit"
pool_size = 5
max_overflow = 5

[secrets]
directory = "/etc/postara/secrets"
fernet_key = "fernet.key"
token_hash_key = "token_hash.key"

[imap]
workers = 8
connect_timeout_seconds = 10
read_timeout_seconds = 30

[security]
api_key_header = "X-Api-Key"
auth_protection_enabled = true
auth_emergency_bypass = false
auth_failure_limit = 5
auth_challenge_threshold = 3
auth_window_seconds = 300
auth_lock_seconds = 300
trusted_proxy_cidrs = ["127.0.0.1/32"]
# turnstile_secret_key = "0x..."

[logging]
level = "INFO"
json = true
